# Required: Notion integration
NOTION_TOKEN=
NOTION_DB_ID=

# Optional: Notion API version
# NOTION_API_VERSION=2022-06-28

# Optional: notice source selection
# BBS_CONFIG_FK=141
# BBS_CONFIG_FKS=141,2
# BBS_CONFIG_CLASSIFY=141:장학공지,2:학사공지
# BBS_CONFIG_LIST_URLS=141:https://www.sogang.ac.kr/ko/scholarship-notice,2:https://www.sogang.ac.kr/ko/academic-support/notices

# Optional: sync behavior
# SYNC_MODE=overwrite
# NOTION_DEDUPE_ON_START=0
# NOTION_ALLOW_TITLE_ONLY_MATCH=0
# NOTION_UPLOAD_FILES=1

# Optional: crawl range
# INCLUDE_NON_TOP=1
# NON_TOP_MAX_PAGES=2
# BBS_PAGE_SIZE=20

# Optional: runtime and debugging
# BROWSER=chromium
# HEADLESS=1
# USER_AGENT="Mozilla/5.0 (compatible; SogangNoticesCrawler/1.0)"
# ATTACHMENT_ALLOWED_DOMAINS=sogang.ac.kr
# ATTACHMENT_MAX_COUNT=15
# ATTACHMENT_SELFTEST=1
# HTML_PATH=
